{
  "manifest_version": 3,
  "name": "Edgeless Sidebar",
  "version": "0.7.0",
  "description": "A permanent browser sidebar with app tower, notes, and calculator",
  "author": "morrowchristian",
  
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "side_panel": {
    "default_path": "ui/panel.html"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_title": "Toggle Edgeless Sidebar",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle Edgeless Sidebar"
    }
  },
  
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}