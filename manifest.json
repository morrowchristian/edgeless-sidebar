{
  "manifest_version": 3,
  "name": "Edgeless Sidebar",
  "version": "0.1.0",
  "description": "An un-copiloted app tower workspace layout. Built because you decided to go Edge-less.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": ["ui/sidebar.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Edgeless Sidebar"
  }
}
